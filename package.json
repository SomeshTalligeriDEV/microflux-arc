{
  "name": "microflux-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix server && npm install --prefix projects/microflux-frontend",
    "build": "npm run build --prefix server && npm run build --prefix projects/microflux-frontend",
    "build:server": "npm run build --prefix server",
    "build:frontend": "npm run build --prefix projects/microflux-frontend",
    "dev:server": "npm run dev --prefix server",
    "dev:frontend": "npm run dev --prefix projects/microflux-frontend",
    "migrate:deploy": "npm run migrate:deploy --prefix server",
    "verify:deploy": "bash scripts/verify-deployment.sh"
  }
}
