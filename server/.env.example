# ======================
# MicroFlux Server — Environment Variables
# Set these in Vercel Dashboard > Settings > Environment Variables
# ======================

PORT=8000

# Database (Neon PostgreSQL)
DATABASE_URL=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI / LLM
GROQ_API_KEY=
MFX_DEBUG_AI=false

# Algorand Wallet (for server-side transaction signing)
ALGORAND_SENDER_MNEMONIC=

# Google Sheets (optional)
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
