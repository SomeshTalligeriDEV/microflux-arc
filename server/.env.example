# ======================
# MicroFlux Server — copy to .env and fill in values
# ======================

PORT=8080

# Database (Neon or any Postgres — required for workflows / users)
DATABASE_URL=

# Telegram Bot (required for bot + /link + notify routes)
TELEGRAM_BOT_TOKEN=
# Optional: default chat for sendTelegramAlert() only
TELEGRAM_CHAT_ID=

# AI / LLM (required for intent + copilot)
GROQ_API_KEY=
MFX_DEBUG_AI=false

# Algorand — one treasury account per deployment (signs server-side workflows: send_payment, atomic_group).
# MUST be in double quotes — spaces in an unquoted line are not loaded (you will see "Missing ALGORAND_SENDER_MNEMONIC").
# Must be Algorand 25-word passphrase (algosdk). Pera Universal 24-word BIP39 phrases will NOT work — use Legacy Algo25 in Pera or algosdk-generated wallet.

# ALGORAND_SENDER_MNEMONIC="word1 word2 ... word25"
ALGORAND_SENDER_MNEMONIC=

# Voice transcription (optional — Telegram voice)
SARVAM_API_KEY=

# Frontend URL — used in Telegram approval links (must match deployed app origin)
WEB_APP_URL=https://microflux.vercel.app

# CORS — comma-separated origins allowed to call the API (browser).
# Defaults include https://microflux.vercel.app and https://microflux-frontend.vercel.app; add more production URLs here.
# Example: https://app.example.com,https://www.example.com
CORS_ORIGINS=

# Secured trigger endpoints (/api/triggers/*). Set in any public deployment.
MICROFLUX_TRIGGER_SECRET=

# Timer scheduler poll interval (ms), minimum 10000
MICROFLUX_TIMER_TICK_MS=30000

# Google Sheets (optional — write_to_spreadsheet)
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
