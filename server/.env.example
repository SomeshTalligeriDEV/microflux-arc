# ======================
# MicroFlux Server — Environment Variables
# Set these in Vercel Dashboard > Settings > Environment Variables
# ======================

PORT=8080

# Database (Neon PostgreSQL)
DATABASE_URL=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI / LLM
GROQ_API_KEY=
MFX_DEBUG_AI=false

# Algorand Wallet (for server-side transaction signing)
ALGORAND_SENDER_MNEMONIC=

# Voice transcription (optional — needed for Telegram voice messages)
SARVAM_API_KEY=

# Frontend URL (for Telegram approval links)
WEB_APP_URL=http://localhost:5173

# Google Sheets (optional)
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
