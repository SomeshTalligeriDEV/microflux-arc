{
  "installCommand": "npm --prefix projects/microflux-frontend install",
  "buildCommand": "npm --prefix projects/microflux-frontend run build",
  "outputDirectory": "projects/microflux-frontend/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
