# ======================
# MicroFlux Frontend (Vite) — copy to .env.local for local dev
# Build-time: set in CI / host (Vercel, etc.)
# ======================

VITE_ENVIRONMENT=production

# Backend API root
# Example: https://your-api.onrender.com
VITE_API_URL=https://microflux-arc.onrender.com

# Algod — TestNet (no token required for public algonode)
VITE_ALGOD_TOKEN=
VITE_ALGOD_SERVER=https://testnet-api.algonode.cloud
VITE_ALGOD_PORT=
VITE_ALGOD_NETWORK=testnet

# Indexer (optional UI features)
VITE_INDEXER_TOKEN=
VITE_INDEXER_SERVER=https://testnet-idx.algonode.cloud
VITE_INDEXER_PORT=

# WorkflowExecutor app (after deploy — TestNet)
VITE_APP_ID=
